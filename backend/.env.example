# Recoup backend — copy to .env and fill. .env is gitignored.

# Gemini — free Google AI Studio key (no card): https://aistudio.google.com/apikey
GOOGLE_API_KEY=
USE_VERTEX=false
GEMINI_MODEL=gemini-3-flash-preview
GOOGLE_CLOUD_PROJECT=

# MongoDB — free Atlas M0 (no card): https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=
MONGODB_DB=recoup

# CORS — comma-separated origins, or * for all
CORS_ORIGINS=*
